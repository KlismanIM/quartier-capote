
---

## 5. .gitignore

```gitignore
# ====================
# DEPENDÊNCIAS
# ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ====================
# ARQUIVOS DO SISTEMA
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
desktop.ini
$RECYCLE.BIN/

# ====================
# AMBIENTE E CONFIGURAÇÃO
# ====================
.env
.env.local
.env.*.local
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# ====================
# ARQUIVOS DE BUILD
# ====================
dist/
build/
.temp/
.cache/
*.log
*.tmp

# ====================
# PROTEÇÃO DE ASSETS (ESTRATÉGICO)
# ====================
# Protege imagens originais/raw (não otimizadas)
img/raw/
img/original/
img/source/
img/*-original.*
img/*.psd
img/*.ai
img/*.sketch
img/*.fig

# Protege vídeos originais (não otimizados)
video/raw/
video/source/
video/original/
video/*-original.*
video/*.mov
video/*.avi
video/*.mkv

# Protege arquivos de design
design/
prototype/
wireframes/
*.psd
*.ai
*.sketch
*.fig
*.xd

# ====================
# BACKUPS E TEMPORÁRIOS
# ====================
*.backup
*.old
*.orig
*.bak
*.tmp
temp/
backup/

# ====================
# RELATÓRIOS E LOGS
# ====================
*.log
logs/
reports/
coverage/

# ====================
# ARQUIVOS DE EDIÇÃO LOCAL
# ====================
*.local
*.local.*
.project
.classpath
.settings/

# ====================
# ARQUIVOS COMPACTADOS
# ====================
*.zip
*.tar
*.gz
*.rar
*.7z

# ====================
# SEGURANÇA
# ====================
# Credenciais e chaves
*.pem
*.key
*.crt
*.p12
.secrets/
secrets/
credentials.json

# ====================
# ARQUIVOS ESPECÍFICOS DO PROJETO
# ====================
# Configurações locais do projeto
.project-config.local
.git/config.local

# Notas pessoais
NOTES.md
TODO.md
personal-notes/